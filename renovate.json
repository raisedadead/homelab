{
  "extends": [
    "github>raisedadead/renovate-config"
  ],
  "packageRules": [
    {
      "groupName": "boto packages",
      "matchPackageNames": [
        "/^boto/"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/ansible/roles/apps/homebridge/defaults/main\\.yml$/"
      ],
      "matchStrings": [
        "homebridge_version:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "homebridge/homebridge",
      "datasourceTemplate": "docker",
      "versioningTemplate": "regex:^(?<major>\\d{4})-(?<minor>\\d{2})-(?<patch>\\d{2})$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/ansible/roles/apps/homeassistant/defaults/main\\.yml$/"
      ],
      "matchStrings": [
        "homeassistant_version:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "home-assistant/home-assistant",
      "datasourceTemplate": "docker",
      "registryUrlTemplate": "https://ghcr.io"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/ansible/roles/apps/portainer/defaults/main\\.yml$/"
      ],
      "matchStrings": [
        "portainer_version:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "portainer/portainer-ce",
      "datasourceTemplate": "docker"
    }
  ]
}
